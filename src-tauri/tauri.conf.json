{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Desk Calendar Dock",
  "version": "1.1.3",
  "identifier": "com.example.deskcalendardock",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Desk Calendar Dock",
        "width": 1440,
        "height": 960,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
